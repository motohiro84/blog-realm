# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Keycloak MySQL設定
# keycloak-mysql-migration/.env.local
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
KEYCLOAK_MYSQL_PORT=3306
KEYCLOAK_MYSQL_DATABASE=keycloak
KEYCLOAK_MYSQL_USER=keycloak
KEYCLOAK_MYSQL_PASSWORD=change_this_password
KEYCLOAK_MYSQL_ROOT_PASSWORD=change_this_root_password

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Blog PostgreSQL設定
# blog-postgres-migration/.env.local
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
BLOG_POSTGRES_PORT=5432
BLOG_POSTGRES_DATABASE=blog
BLOG_POSTGRES_USER=admin
BLOG_POSTGRES_PASSWORD=change_this_password

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Prisma設定（blog-postgres-migration/.envに記載）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
DATABASE_URL="postgresql://admin:change_this_password@localhost:5432/blog?schema=public"

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Keycloak（認証サーバー）設定
# auth-service/.env.local
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
KEYCLOAK_PORT=8081
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=change_this_password
KEYCLOAK_DB_HOST=keycloak-mysql
KEYCLOAK_DB_PORT=3306
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=change_this_password

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# SeaweedFS（オブジェクトストレージ）設定
# seaweedfs-storage/.env.local
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
SEAWEEDFS_MASTER_PORT=9333
SEAWEEDFS_VOLUME_PORT=8080
SEAWEEDFS_FILER_PORT=8888
SEAWEEDFS_S3_PORT=8333
SEAWEEDFS_S3_ACCESS_KEY=blog_admin
SEAWEEDFS_S3_SECRET_KEY=change_this_password

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Elasticsearch設定
# elasticsearch/.env.local
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
ES_PORT=9200
ES_JAVA_OPTS=-Xms512m -Xmx512m
ELASTIC_PASSWORD=change_this_password

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Spring Boot（管理画面API）設定
# blog-admin-server/.env.local
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
SPRING_BOOT_PORT=4000
SPRING_DB_HOST=blog-postgres
SPRING_DB_PORT=5432
SPRING_DB_NAME=blog
SPRING_DB_USER=admin
SPRING_DB_PASSWORD=change_this_password
SEAWEEDFS_ENDPOINT=http://seaweedfs-s3:8333
SEAWEEDFS_ACCESS_KEY=blog_admin
SEAWEEDFS_SECRET_KEY=change_this_password
SEAWEEDFS_BUCKET=blog-images
KEYCLOAK_AUTH_SERVER_URL=http://keycloak:8080
KEYCLOAK_REALM=blog-realm
KEYCLOAK_CLIENT_ID=blog-admin
KEYCLOAK_CLIENT_SECRET=change_this_secret

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Angular（管理画面フロントエンド）設定
# blog-admin-client/.env.local
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
ANGULAR_PORT=3000
API_URL=http://localhost:4000
KEYCLOAK_URL=http://localhost:8081
SEAWEEDFS_PUBLIC_URL=http://localhost:8333

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# NestJS（公開ブログAPI）設定
# blog-public-server/.env
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
NEST_PORT=4001
DATABASE_URL="postgresql://admin:change_this_password@blog-postgres:5432/blog?schema=public"
SEAWEEDFS_ENDPOINT=http://seaweedfs-s3:8333
SEAWEEDFS_PUBLIC_URL=http://localhost:8333
ELASTICSEARCH_NODE=http://elasticsearch:9200
ELASTICSEARCH_PASSWORD=change_this_password

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Next.js（公開ブログフロントエンド）設定
# blog-public-client/.env.local
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
NEXT_PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:4001
NEXT_PUBLIC_SEAWEEDFS_URL=http://localhost:8333
